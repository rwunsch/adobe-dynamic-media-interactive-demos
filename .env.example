# Copy this file to ".env" (which is gitignored) and fill in your own values.
# Only the approval helper script (flip-approval.sh, used by demo 18) reads this —
# the demos themselves are static client-side HTML and need no secrets.

# AEM author instance (basic-auth) used to set Review Status + publish.
INSTANCE_URL=https://author-pXXXXX-eYYYYYY.adobeaemcloud.com
USER=your-aem-username
PASSWORD=your-aem-password

# Dynamic Media OpenAPI delivery host (program/environment specific).
DELIVERY_HOST=delivery-pXXXXX-eYYYYYY.adobeaemcloud.com
